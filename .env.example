# Application
PORT=3000

# Database
DATABASE_URL="postgresql://marketscooper:marketscooper@localhost:5434/marketscooper?schema=public"
DB_PORT=5434

# AI Provider: "openai" or "anthropic"
AI_PROVIDER="openai"

# OpenAI
OPENAI_API_KEY="sk-..."

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."

# AI Model overrides (optional)
OPENAI_MODEL="gpt-4o-mini"
ANTHROPIC_MODEL="claude-sonnet-4-6"
